{
  "name": "nemesis-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-04-05",
  "durable_objects": {
    "bindings": [
      {
        "name": "TRACE_SESSION_DO",
        "class_name": "TraceSessionDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TraceSessionDO"]
    }
  ],
  "queues": {
    "producers": [
      {
        "queue": "nemesis-darknet-queue",
        "binding": "DARKNET_QUEUE"
      }
    ],
    "consumers": [
      {
        "queue": "nemesis-darknet-queue",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  },
  "vars": {
    "ENVIRONMENT": "production"
  }
}
