    "canonical_patterns": {
        "EVM_COMMON": {
            "wallet": "/address/{address}",
            "transaction": "/tx/{txhash}",
            "token": "/token/{token}",
            "nft": "/token/{contract}?a={tokenId}",
            "block": "/block/{block}",
            "validator": "/validator/{validator}",
            "contract_source": "/address/{address}#code",
            "read_contract": "/address/{address}#readContract",
            "write_contract": "/address/{address}#writeContract",
            "analytics": "/address/{address}#analytics",
            "assets": "/address/{address}#multichain-portfolio",
            "erc20_transfers": "/address/{address}#tokentxns",
            "erc721_transfers": "/address/{address}#tokentxnsNFT",
            "internal_txs": "/txsInternal?a={address}",
            "logs": "/tx/{txhash}#eventlog"
        }
    },
    "explorers": {
        "Ethereum": {"name": "Etherscan", "base_url": "https://etherscan.io", "patterns": "EVM_COMMON"},
        "Base": {"name": "Basescan", "base_url": "https://basescan.org", "patterns": "EVM_COMMON"},
        "Arbitrum": {"name": "Arbiscan", "base_url": "https://arbiscan.io", "patterns": "EVM_COMMON"},
        "Optimism": {"name": "Optimistic Etherscan", "base_url": "https://optimistic.etherscan.io", "patterns": "EVM_COMMON"},
        "Polygon": {"name": "Polygonscan", "base_url": "https://polygonscan.com", "patterns": "EVM_COMMON"},
        "BSC": {"name": "BscScan", "base_url": "https://bscscan.com", "patterns": "EVM_COMMON"}
    },
    "pagination_schemes": [
